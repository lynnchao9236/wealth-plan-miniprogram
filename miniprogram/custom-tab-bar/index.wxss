/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-border {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1rpx;
  background: #E5E5E5;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 48rpx;
  color: #8A8A8A;
}

.tab-icon.active {
  color: #07C160;
}

.tab-text {
  font-size: 20rpx;
  color: #8A8A8A;
  margin-top: 2rpx;
}

.tab-text.active {
  color: #07C160;
  font-weight: 600;
}
