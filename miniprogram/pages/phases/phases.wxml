<!--pages/phases/phases.wxml - 阶段详情页-->
<view class="page-wrap">
  <!-- 阶段Tab切换 -->
  <view class="phase-tabs">
    <view class="phase-tab {{currentPhase === '1' ? 'active' : ''}}" bindtap="switchPhase" data-phase="1">🔵 Phase 1</view>
    <view class="phase-tab {{currentPhase === '2' ? 'active' : ''}}" bindtap="switchPhase" data-phase="2">🟡 Phase 2</view>
    <view class="phase-tab {{currentPhase === '3' ? 'active' : ''}}" bindtap="switchPhase" data-phase="3">🟢 Phase 3</view>
    <view class="phase-tab {{currentPhase === 'house' ? 'active' : ''}}" bindtap="switchPhase" data-phase="house">🏠 换房</view>
  </view>

  <scroll-view scroll-y class="content-scroll">
    <!-- Phase 1/2/3 内容 -->
    <block wx:if="{{currentPhase !== 'house'}}">
      <!-- 阶段概览卡片 -->
      <view class="gradient-card" style="margin-top: 20rpx; background: linear-gradient(135deg, {{phaseInfo.gradientFrom}}, {{phaseInfo.gradientTo}}); box-shadow: 0 8rpx 24rpx {{phaseInfo.shadow}};">
        <text style="font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 8rpx; color: #fff;">{{phaseInfo.title}}</text>
        <text style="font-size: 24rpx; opacity: 0.9; display: block; margin-bottom: 16rpx; color: #fff;">{{phaseInfo.period}} · {{phaseInfo.age}}</text>
        <view class="flex-row" style="gap: 24rpx;">
          <view>
            <text style="font-size: 22rpx; opacity: 0.8; display: block; color: #fff;">起始资产</text>
            <text style="font-size: 32rpx; font-weight: bold; color: #fff;">¥{{phaseInfo.startAsset}}万</text>
          </view>
          <text style="font-size: 32rpx; color: #fff; opacity: 0.6;"> → </text>
          <view>
            <text style="font-size: 22rpx; opacity: 0.8; display: block; color: #fff;">目标资产</text>
            <text style="font-size: 32rpx; font-weight: bold; color: #fff;">¥{{phaseInfo.targetAsset}}万</text>
          </view>
        </view>
      </view>

      <!-- 核心策略 -->
      <view class="card" style="margin-top: 24rpx;">
        <text class="text-bold" style="font-size: 28rpx; display: block; margin-bottom: 16rpx;">🎯 核心策略</text>
        <view class="strategy-item" wx:for="{{phaseInfo.strategies}}" wx:key="title">
          <view class="strategy-icon" style="background: {{item.bgColor}};">
            <text style="font-size: 28rpx;">{{item.icon}}</text>
          </view>
          <view style="flex: 1;">
            <text class="text-bold" style="font-size: 26rpx; display: block;">{{item.title}}</text>
            <text class="text-desc" style="font-size: 22rpx; display: block; margin-top: 4rpx;">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 投资配比 -->
      <view class="card" style="margin-top: 24rpx;">
        <text class="text-bold" style="font-size: 28rpx; display: block; margin-bottom: 16rpx;">📊 投资配比</text>
        <view class="ratio-item" wx:for="{{phaseInfo.portfolio}}" wx:key="name">
          <view class="flex-row" style="gap: 12rpx; flex: 1;">
            <view style="width: 12rpx; height: 12rpx; border-radius: 50%; background: {{item.color}}; flex-shrink: 0;"></view>
            <text style="font-size: 26rpx;">{{item.name}}</text>
          </view>
          <view class="ratio-bar">
            <view class="ratio-fill" style="width: {{item.value}}%; background: {{item.color}};"></view>
          </view>
          <text class="text-bold" style="font-size: 24rpx; width: 80rpx; text-align: right;">{{item.value}}%</text>
        </view>
      </view>

      <!-- 年度资金流 -->
      <view class="card" style="margin-top: 24rpx;">
        <text class="text-bold" style="font-size: 28rpx; display: block; margin-bottom: 16rpx;">💰 年度资金流</text>
        <view class="fund-flow">
          <view class="fund-row" wx:for="{{phaseInfo.annualFlow}}" wx:key="label">
            <text style="font-size: 26rpx; flex: 1;">{{item.label}}</text>
            <text class="text-bold" style="font-size: 26rpx; color: {{item.color}};">{{item.value}}</text>
          </view>
        </view>
      </view>

      <!-- 关键里程碑 -->
      <view class="card" style="margin-top: 24rpx; margin-bottom: 40rpx;">
        <text class="text-bold" style="font-size: 28rpx; display: block; margin-bottom: 16rpx;">🏁 关键里程碑</text>
        <view class="milestone-item" wx:for="{{phaseInfo.milestones}}" wx:key="title">
          <view class="milestone-dot" style="background: {{phaseInfo.color}};"></view>
          <view style="flex: 1;">
            <text class="text-bold" style="font-size: 26rpx; display: block;">{{item.title}}</text>
            <text class="text-desc" style="font-size: 22rpx; display: block; margin-top: 4rpx;">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 换房阶段 -->
    <block wx:if="{{currentPhase === 'house'}}">
      <view class="gradient-card" style="margin-top: 20rpx; background: linear-gradient(135deg, #EC4899, #DB2777); box-shadow: 0 8rpx 24rpx rgba(236,72,153,0.3);">
        <text style="font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 8rpx; color: #fff;">🏠 换房计划</text>
        <text style="font-size: 24rpx; opacity: 0.9; display: block; color: #fff;">2034–2036年 · 43~45岁</text>
      </view>

      <view class="card" style="margin-top: 24rpx;">
        <text class="text-bold" style="font-size: 28rpx; display: block; margin-bottom: 16rpx;">换房策略</text>
        <view class="strategy-item" wx:for="{{houseStrategies}}" wx:key="title">
          <view class="strategy-icon" style="background: {{item.bgColor}};">
            <text style="font-size: 28rpx;">{{item.icon}}</text>
          </view>
          <view style="flex: 1;">
            <text class="text-bold" style="font-size: 26rpx; display: block;">{{item.title}}</text>
            <text class="text-desc" style="font-size: 22rpx; display: block; margin-top: 4rpx;">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="card" style="margin-top: 24rpx; margin-bottom: 40rpx;">
        <text class="text-bold" style="font-size: 28rpx; display: block; margin-bottom: 16rpx;">⚠️ 铁律</text>
        <view class="tip-box" style="background: #FEF2F2; color: #B91C1C;">
          换房首付只动固收部分 + 卖旧房所得，绝不触碰权益仓（股票/基金），保住复利引擎！
        </view>
      </view>
    </block>
  </scroll-view>
</view>
