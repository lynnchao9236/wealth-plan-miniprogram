/* pages/investment/investment.wxss */
.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F6F6F6;
}

.content-scroll {
  flex: 1;
  overflow: hidden;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-row {
  display: flex;
  align-items: center;
}

.text-bold { font-weight: 600; }
.text-desc { color: #8A8A8A; }

.update-btn {
  font-size: 22rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #FFFFFF;
}

/* Tab切换 */
.invest-tabs {
  display: flex;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E5E5E5;
}

.invest-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #8A8A8A;
  border-bottom: 4rpx solid transparent;
}

.invest-tab.active {
  color: #191919;
  font-weight: 600;
  border-bottom-color: #8B5CF6;
}

/* 持仓列表 */
.holding-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.holding-item:last-child {
  border-bottom: none;
}

/* 占比条 */
.pie-bar {
  display: flex;
  height: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.pie-segment {
  height: 20rpx;
}

/* 建议 */
.advice-item {
  background: #F9F9F9;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.advice-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.advice-detail {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx;
}
/* 记录 */
.record-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  margin: 12rpx 24rpx 0;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

/* 编辑 */
.add-btn {
  text-align: center;
  color: #8B5CF6;
  font-size: 26rpx;
  padding: 16rpx;
  background: #F3F0FF;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

/* 编辑弹窗 - 账户区块 */
.edit-account-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

/* 编辑弹窗 - 持仓卡片 */
.edit-holding-card {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E5E7EB;
}

/* 编辑字段标签 */
.edit-field-label {
  font-size: 22rpx;
  color: #8A8A8A;
  margin-bottom: 8rpx;
  margin-top: 12rpx;
}

/* 编辑字段输入框 */
.edit-field-input {
  width: 100%;
  height: 72rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 编辑字段文本域 */
.edit-field-textarea {
  width: 100%;
  min-height: 60rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* ===== 账户头两行布局 ===== */
.edit-account-header {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin-bottom: 16rpx;
}

.edit-account-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
  width: 100%;
}

.edit-account-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.edit-account-name-input {
  flex: 1;
  min-width: 0;
  font-weight: 600;
}
.edit-account-name-input.stock {
  background: #F3F0FF;
  border-color: #DDD6FE;
  color: #3B82F6;
}

.edit-account-name-input.fund {
  background: #E0F7FA;
  border-color: #B2EBF2;
  color: #06B6D4;
}

.edit-account-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: wrap;
  width: 100%;
  padding-top: 12rpx;
  border-top: 1rpx dashed #E5E7EB;
}

.edit-action-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.edit-action-btn.batch-btn.stock {
  color: #3B82F6;
  background: #EFF6FF;
  border: 1rpx solid #DBEAFE;
}

.edit-action-btn.batch-btn.fund {
  color: #06B6D4;
  background: #ECFEFF;
  border: 1rpx solid #CFFAFE;
}

.edit-action-btn.add-btn-sm.stock {
  color: #FFFFFF;
  background: linear-gradient(135deg, #3B82F6, #6366F1);
  font-weight: 600;
}

.edit-action-btn.add-btn-sm.fund {
  color: #FFFFFF;
  background: linear-gradient(135deg, #8B5CF6, #06B6D4);
  font-weight: 600;
}

.edit-action-btn.del-btn {
  color: #FA5151;
  background: #FEF2F2;
  border: 1rpx solid #FEE2E2;
}

/* 币种选择器 */
.currency-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.currency-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 64rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: #FFFFFF;
}

.currency-btn.active {
  border-color: #8B5CF6;
  background: #F3F0FF;
  color: #8B5CF6;
  font-weight: 600;
}

/* ===== 批量识别弹窗 ===== */
.batch-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 10100;
  max-height: 90vh;
  display: flex;  flex-direction: column;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.12);
}

.batch-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.batch-tip-box {
  background: #F3F0FF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.batch-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.batch-preview-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.batch-preview-item:last-child {
  border-bottom: none;
}

.batch-preview-idx {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #F3F0FF;
  color: #8B5CF6;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.batch-preview-code {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.stock-code {
  background: #EFF6FF;
  color: #3B82F6;
}

.fund-code {
  background: #F3F0FF;
  color: #8B5CF6;
}

.batch-confirm-btn {
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.stock-btn {
  background: linear-gradient(135deg, #3B82F6, #6366F1);
}

.fund-btn {
  background: linear-gradient(135deg, #8B5CF6, #06B6D4);
}

/* ===== 配比对比卡片 ===== */
.card {
  background: #FFFFFF;
  margin: 0 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.alloc-legend {  display: flex;
  gap: 24rpx;
  padding: 10rpx 0 18rpx;
  font-size: 20rpx;
  color: #6B7280;
}
.alloc-legend .legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.legend-dot {
  width: 20rpx;
  height: 12rpx;
  border-radius: 4rpx;
}
.legend-dot-target {
  background: linear-gradient(90deg, #CBD5E1 0%, #94A3B8 100%);
  opacity: 0.6;
}
.legend-dot-actual {
  background: #8B5CF6;
}

.alloc-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.alloc-row:last-child {
  border-bottom: none;
}
.alloc-row-sub {
  padding: 12rpx 0 12rpx 12rpx;
  border-bottom: 1rpx dashed #F3F4F6;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.bar-label {
  width: 56rpx;
  font-size: 20rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 14rpx;
  background: #F3F4F6;
  border-radius: 7rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s ease;
}
.bar-fill-target {
  opacity: 0.38;
}
.bar-val {
  min-width: 110rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.alloc-amount {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}

.status-chip {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* 类型分组 */
.type-group {
  margin-top: 16rpx;
  background: #FAFAFB;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}
.type-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 10rpx;
  border-bottom: 1rpx solid #E5E7EB;
  margin-bottom: 4rpx;}
.type-group-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #374151;
}
.type-group-stat {
  font-size: 20rpx;
  color: #8A8A8A;
}

/* ===== 新增样式 - 账户选择器 ===== */

/* 账户选择弹窗 */
.acc-picker-modal {
  border-radius: 32rpx 32rpx 0 0;
}

.acc-picker-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.acc-type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: #FFFFFF;
}

.acc-type-stock-active {
  border-color: #3B82F6;
  background: #EFF6FF;
  color: #3B82F6;
  font-weight: 600;
}

.acc-type-fund-active {
  border-color: #06B6D4;
  background: #ECFEFF;
  color: #06B6D4;
  font-weight: 600;
}

/* ===== 持仓列表 - 编辑账户名按钮 ===== */
.edit-acc-btn {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #EFF6FF;
  color: #3B82F6;
  border: 1rpx solid #DBEAFE;
  flex-shrink: 0;
}

.edit-acc-btn.fund-acc {
  background: #ECFEFF;
  color: #06B6D4;
  border-color: #CFFAFE;
}

/* 单项删除按钮 */
.item-del-btn {
  font-size: 28rpx;
  padding: 8rpx 12rpx;
  color: #FA5151;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 币种标签 */
.currency-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  background: #FFF7ED;
  color: #D97706;
  font-weight: 600;
}

.currency-tag.cyan-tag {
  background: #ECFEFF;
  color: #06B6D4;
}

/* ===== 批量识别 - 预览编辑卡片 ===== */
.batch-preview-edit-card {
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.preview-edit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.preview-field-label {
  font-size: 22rpx;
  color: #8A8A8A;
  flex-shrink: 0;
  width: 60rpx;
}

.preview-field-input {
  flex: 1;
  height: 60rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.preview-currency-btn {
  padding: 8rpx 20rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #666;
  background: #FFFFFF;
}

.preview-currency-btn.active {
  border-color: #8B5CF6;
  background: #F3F0FF;
  color: #8B5CF6;
  font-weight: 600;
}

/* ===== modal 通用定位（必须高于蒙层） ===== */
.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  z-index: 10200;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.12);
}

/* ===== 单项编辑弹窗 ===== */
.item-edit-modal {
  border-radius: 32rpx 32rpx 0 0;
}

/* ===== 账户改名弹窗 ===== */
.acc-rename-modal {
  border-radius: 32rpx 32rpx 0 0;
  z-index: 10300;
}
